# Copy to .env and fill in. NEVER commit .env.

# Your unified social-posting API key (Ayrshare → Dashboard → API Key).
AYRSHARE_API_KEY=your_ayrshare_api_key_here

# Free image hosting for posts with images (Instagram requires a public image URL).
# Get a free key at https://api.imgbb.com/  (sign in → "Get API key").
IMGBB_API_KEY=your_imgbb_api_key_here

# Optional: only for multi-user (Business plan) per-user account linking.
# AYRSHARE_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...

# Optional: post to LinkedIn directly (free, official) instead of via Ayrshare,
# so LinkedIn doesn't use the Ayrshare quota. Requires a member access token
# (scope w_member_social) and your author URN (e.g. urn:li:person:XXXX).
# Create an app at https://www.linkedin.com/developers/ and generate a token.
# LINKEDIN_ACCESS_TOKEN=your_linkedin_member_token
# LINKEDIN_AUTHOR_URN=urn:li:person:XXXXXXXX

# Optional overrides
# AYRSHARE_API_URL=https://app.ayrshare.com/api
# PORT=3000
